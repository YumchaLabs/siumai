{
  "model": "gpt-5-nano",
  "input": [
    {
      "role": "user",
      "content": [
        {
          "type": "input_text",
          "text": "Return a person object"
        }
      ]
    }
  ],
  "text": {
    "format": {
      "type": "json_schema",
      "name": "person",
      "description": "Structured person payload",
      "strict": true,
      "schema": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "age": { "type": "integer" }
        },
        "required": ["name"],
        "additionalProperties": false
      }
    }
  }
}
